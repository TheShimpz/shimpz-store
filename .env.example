# Copy to .env (gitignored) and fill in. shimpz-new generates real values on a real machine.
DATABASE_URL=
SECRET_KEY=
# Logging is process env (NOT read from .env): LOG_FORMAT=console for human dev output (default json),
# LOG_LEVEL=DEBUG to see debug lines (default INFO). Set them in the shell, e.g. LOG_FORMAT=console uv run ...
